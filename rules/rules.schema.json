{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CP Tracker Rules",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at",
    "source_sheet_id",
    "confidence",
    "notes",
    "column_map",
    "value_maps",
    "normalizers"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "source_sheet_id": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "notes": {
      "type": "string"
    },
    "column_map": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "header",
          "index"
        ],
        "properties": {
          "header": {
            "type": "string",
            "minLength": 1
          },
          "index": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "value_maps": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      }
    },
    "normalizers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}

